{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "check": "npm run check --workspaces",
    "test": "npm run test --workspaces",
    "release:changed:patch:publish": "node scripts/release-changed.mjs --bump=patch",
    "release:changed:minor:publish": "node scripts/release-changed.mjs --bump=minor",
    "release:changed:major:publish": "node scripts/release-changed.mjs --bump=major",
    "release:changed:dry-run": "node scripts/release-changed.mjs --dry-run",
    "submit": "audit-code submit-packet"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "~5.8"
  }
}
