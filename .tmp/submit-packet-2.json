        ],
        "evidence": [
          "packages/audit-code/src/cli/dispatch.ts:538 - `const submitCommand = 'node packages/audit-code/audit-code.mjs submit-packet ' ...` hardcodes the script path instead of using the generic `audit-code` executable."
        ]
      },
