{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "unit_manifest.schema.json",
  "title": "Audit Unit Manifest",
  "type": "object",
  "required": ["units"],
  "properties": {
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "name", "files", "required_lenses"],
        "properties": {
          "unit_id": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "risk_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "required_lenses": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "lens.schema.json" }
          },
          "critical_flows": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
