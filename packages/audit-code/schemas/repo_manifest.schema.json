{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo_manifest.schema.json",
  "title": "Repository Manifest",
  "type": "object",
  "required": ["repository", "generated_at", "files"],
  "properties": {
    "repository": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" },
        "default_branch": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generated_at": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "language", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "language": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "hash": { "type": "string" },
          "excluded": { "type": "boolean" },
          "exclusion_reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
