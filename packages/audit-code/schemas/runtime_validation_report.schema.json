{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime_validation_report.schema.json",
  "title": "Runtime Validation Report",
  "type": "object",
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "status", "summary"],
        "properties": {
          "task_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "not_confirmed", "inconclusive", "not_required"]
          },
          "summary": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
