{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "risk_register.schema.json",
  "title": "Risk Register",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "risk_score", "signals"],
        "properties": {
          "unit_id": { "type": "string" },
          "risk_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "signals": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
