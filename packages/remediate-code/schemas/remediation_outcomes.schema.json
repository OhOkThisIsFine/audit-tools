{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "remediation_outcomes.schema.json",
  "title": "Remediation Outcomes Report",
  "description": "Phase 7B per-finding outcome capture emitted at close time. Capture/surface only; not consumed automatically by the auditor.",
  "type": "object",
  "required": ["contract_version", "total", "by_outcome", "by_lens", "outcomes"],
  "properties": {
    "contract_version": { "const": "remediate-code-outcomes/v1alpha1" },
    "total": { "type": "integer", "minimum": 0 },
    "started_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "duration_ms": { "type": "number", "minimum": 0 },
    "by_outcome": {
      "type": "object",
      "required": [
        "resolved",
        "verified_no_change",
        "inappropriate",
        "ignored",
        "blocked"
      ],
      "properties": {
        "resolved": { "type": "integer", "minimum": 0 },
        "verified_no_change": { "type": "integer", "minimum": 0 },
        "inappropriate": { "type": "integer", "minimum": 0 },
        "ignored": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "by_lens": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "resolved": { "type": "integer", "minimum": 0 },
          "verified_no_change": { "type": "integer", "minimum": 0 },
          "inappropriate": { "type": "integer", "minimum": 0 },
          "ignored": { "type": "integer", "minimum": 0 },
          "blocked": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "outcomes": {
      "type": "array",
      "items": { "$ref": "#/$defs/remediation_outcome" }
    },
    "ended_at": { "type": "string" },
    "step_count": { "type": "integer", "minimum": 0 },
    "combined_test_result": {
      "type": "object",
      "required": ["passed"],
      "properties": {
        "passed": { "type": "boolean" },
        "suite_name": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "failure_summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "e2e_result": {
      "type": "object",
      "required": ["passed"],
      "properties": {
        "passed": { "type": "boolean" },
        "suite_name": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "failure_summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "closing_result": {
      "type": "object",
      "required": ["action", "status"],
      "properties": {
        "action": { "$ref": "shared.schema.json#/$defs/closing_action" },
        "status": { "type": "string", "enum": ["success", "skipped", "failed"] },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "exit_code"],
            "properties": {
              "command": { "type": "array", "items": { "type": "string" } },
              "exit_code": { "type": ["integer", "null"] },
              "stdout": { "type": "string" },
              "stderr": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "plan_coverage": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "remediation_outcome": {
      "type": "object",
      "required": [
        "finding_id",
        "lens",
        "file_exts",
        "outcome",
        "rework_count",
        "closing_status"
      ],
      "properties": {
        "finding_id": { "type": "string" },
        "lens": { "type": "string" },
        "file_exts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outcome": {
          "type": "string",
          "enum": [
            "resolved",
            "verified_no_change",
            "inappropriate",
            "ignored",
            "blocked"
          ]
        },
        "rework_count": { "type": "integer", "minimum": 0 },
        "closing_status": { "type": "string" },
        "closing_status_reason": { "type": "string" },
        "started_at": { "type": "string" },
        "completed_at": { "type": "string" },
        "duration_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
