{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker_result.schema.json",
  "title": "Remediation Worker Result",
  "oneOf": [
    {
      "type": "object",
      "required": ["type", "contract_version", "phase", "item_spec"],
      "properties": {
        "type": { "const": "item_spec" },
        "contract_version": { "const": "remediate-code-worker-result/v1alpha1" },
        "phase": { "const": "document" },
        "item_spec": { "$ref": "item_spec.schema.json" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "contract_version", "phase", "clarifications"],
      "properties": {
        "type": { "const": "clarification_request" },
        "contract_version": { "const": "remediate-code-worker-result/v1alpha1" },
        "phase": { "const": "document" },
        "clarifications": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "clarification_request.schema.json" }
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "contract_version", "phase", "item_results"],
      "properties": {
        "type": { "const": "implement_result" },
        "contract_version": {
          "const": "remediate-code-worker-result/v1alpha1"
        },
        "phase": { "const": "implement" },
        "item_results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["finding_id", "status"],
            "properties": {
              "finding_id": { "type": "string" },
              "status": { "type": "string", "enum": ["resolved", "blocked"] },
              "evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "failure_reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  ]
}
