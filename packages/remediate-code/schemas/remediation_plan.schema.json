{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "remediation_plan.schema.json",
  "title": "Remediation Plan",
  "type": "object",
  "required": [
    "plan_id",
    "findings",
    "blocks",
    "project_type",
    "candidate_closing_actions"
  ],
  "properties": {
    "plan_id": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "$ref": "finding.schema.json" }
    },
    "blocks": {
      "type": "array",
      "items": { "$ref": "remediation_block.schema.json" }
    },
    "project_type": { "type": "string" },
    "test_command": { "type": "string" },
    "e2e_command": { "type": "string" },
    "candidate_closing_actions": {
      "type": "array",
      "items": {
        "$ref": "shared.schema.json#/$defs/closing_action"
      }
    },
    "block_strategy": {
      "type": "string",
      "enum": ["test_graph", "git_cocommit", "file_overlap", "manual"]
    }
  },
  "additionalProperties": false
}
