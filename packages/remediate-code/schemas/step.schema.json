{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "step.schema.json",
  "title": "Remediation Step",
  "type": "object",
  "required": [
    "contract_version",
    "step_kind",
    "status",
    "prompt_path",
    "run_id",
    "repo_root",
    "artifacts_dir",
    "allowed_commands",
    "stop_condition",
    "artifact_paths"
  ],
  "properties": {
    "contract_version": { "const": "remediate-code-step/v1alpha1" },
    "step_kind": { "type": "string" },
    "status": { "type": "string", "enum": ["ready", "blocked", "complete"] },
    "prompt_path": { "type": "string" },
    "run_id": { "type": "string" },
    "repo_root": { "type": "string" },
    "artifacts_dir": { "type": "string" },
    "allowed_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stop_condition": { "type": "string" },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "access": { "$ref": "shared.schema.json#/$defs/access_declaration" }
  },
  "additionalProperties": false
}
