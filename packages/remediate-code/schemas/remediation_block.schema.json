{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "remediation_block.schema.json",
  "title": "Remediation Block",
  "type": "object",
  "required": ["block_id", "items", "parallel_safe"],
  "properties": {
    "block_id": { "type": "string" },
    "items": {
      "type": "array",
      "items": { "type": "string", "description": "finding id" },
      "minItems": 1
    },
    "parallel_safe": { "type": "boolean" },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "block ids this block depends on"
      }
    }
  },
  "additionalProperties": false
}
